# ============================================================
# jul-IA — variables de entorno
# Copia este fichero a .env.local (Next) / .env (worker) y rellena.
# ============================================================

# --- Supabase ---------------------------------------------------------------
# Esquema NUEVO de claves (publishable/secret). Soporta también el legacy
# (anon/service_role): si solo tienes las legacy, ponlas en estas mismas vars.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública para el cliente (navegador). Legacy equivalente: anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Clave secreta SOLO servidor/worker. NUNCA exponer al cliente.
# Legacy equivalente: service_role key.
SUPABASE_SECRET_KEY=

# Conexión directa a Postgres para el worker de ingesta.
# Local Supabase por defecto: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# --- Proveedor de IA (chat) -------------------------------------------------
# anthropic | openai
CHAT_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o

# --- Embeddings (siempre OpenAI) --------------------------------------------
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Worker de ingesta ------------------------------------------------------
INGEST_POLL_INTERVAL_MS=3000
INGEST_MAX_ATTEMPTS=3
INGEST_LOCK_TIMEOUT_SECONDS=300
INGEST_MAX_CHUNK_CHARS=4000

# --- URLs de referencia -----------------------------------------------------
# Dominios permitidos para indexar URLs (coma-separado). Si se omite, se usa una
# allowlist oficial por defecto (boe.es, agenciatributaria.gob.es, seg-social.es…).
REFERENCE_URL_ALLOWLIST=

# --- Acceso -----------------------------------------------------------------
# true para exigir login; false abre la app (no recomendado con docs sensibles).
REQUIRE_AUTH=true

# Registro: por defecto CERRADO. Pon 'true' para permitir alta pública.
ALLOW_PUBLIC_SIGNUP=false
# Si el registro está cerrado, solo estos correos pueden darse de alta (coma).
SIGNUP_ALLOWLIST=
